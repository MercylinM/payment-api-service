{
  "name": "payment-api-service",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "ts-node src/app.ts",
    "migrate": "node -r ts-node/register src/db/migrate.ts",
    "test": "jest --runInBand --forceExit",
    "worker": "ts-node src/worker/processor.ts",
    "quickstart": "bash scripts/quickstart.sh"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "decimal.js": "^10.4.3",
    "express": "^4.18.2",
    "js-yaml": "^5.2.1",
    "pg": "^8.11.3",
    "prom-client": "^15.1.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/nock": "^11.1.0",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "nock": "^13.5.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "testTimeout": 30000
  }
}
